# Core runtime only (minimal local setup)
# Optional Gmail OAuth / SMTP / test config are documented in README.
APP_API_KEY=dev-api-key-change-me
APP_SECRET_KEY=7J2Btjj4GW8jIP5MErM81QOZeK4c7xYknVxKsgKMnmk=
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/deadline_diff
ENABLE_NOTIFICATIONS=false
NOTIFY_SINK_MODE=smtp
NOTIFY_JSONL_PATH=data/smoke/notify_sink.jsonl
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your-account@gmail.com
SMTP_PASSWORD=google-app-password
SMTP_FROM_NAME=CalendarDIFF
SMTP_FROM_EMAIL=your-account@gmail.com
DEFAULT_EMAIL=
PUBLIC_WEB_ORIGINS=http://localhost:8200,http://127.0.0.1:8200

# Optional: bootstrap a local admin/login account on startup.
# This is useful for local demos or quick testing after a database reset.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_TIMEZONE_NAME=America/Los_Angeles

# Optional: Gmail OAuth (only needed if you use Gmail OAuth callbacks)
# Use a Google OAuth client secrets file (Web application) and keep it outside this repository.
APP_BASE_URL=http://localhost:8200
FRONTEND_APP_BASE_URL=http://127.0.0.1:3000
OAUTH_PUBLIC_BASE_URL=http://localhost:8200
OAUTH_ROUTE_PREFIX=
OAUTH_SESSION_ROUTE_TEMPLATE=/sources/{source_id}/oauth-sessions
OAUTH_CALLBACK_ROUTE_TEMPLATE=/oauth/callbacks/{provider}
OAUTH_CALLBACK_REQUIRE_API_KEY=false
OAUTH_STATE_TTL_MINUTES=10
# Optional override; falls back to APP_SECRET_KEY when empty.
OAUTH_TOKEN_ENCRYPTION_KEY=
# When using docker compose, HOST_SECRETS_DIR is mounted read-only into public-service
# at the same absolute path. Keep the Gmail client secrets file under that directory.
HOST_SECRETS_DIR=/tmp/calendardiff-secrets
GMAIL_OAUTH_CLIENT_SECRETS_FILE=/tmp/calendardiff-secrets/google_client_secret.json
# The file can be .json or .jsonl, but must contain Google client secrets JSON with a "web" object.
# The generated redirect URI must exist in "web.redirect_uris". With defaults it is:
#   http://localhost:8200/oauth/callbacks/gmail
# Recommended: chmod 700 /tmp/calendardiff-secrets && chmod 600 /tmp/calendardiff-secrets/google_client_secret.json
# Keep readonly unless you intentionally expand scopes
GMAIL_OAUTH_SCOPE=https://www.googleapis.com/auth/gmail.readonly
GMAIL_OAUTH_ACCESS_TYPE=offline
GMAIL_OAUTH_PROMPT=consent
GMAIL_OAUTH_INCLUDE_GRANTED_SCOPES=true
# Optional: endpoint overrides (used for local fake Gmail provider smoke tests)
GMAIL_API_BASE_URL=https://gmail.googleapis.com/gmail/v1/users/me
GMAIL_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GMAIL_OAUTH_AUTHORIZE_URL=https://accounts.google.com/o/oauth2/v2/auth
# Optional: Gmail secondary suppressor between deterministic prefilter and LLM.
# Deployment default is `off`.
# - off: do not call the secondary filter
# - shadow: call it, but never let it suppress the main result path
# - enforce: allow it to suppress after the recall-first deterministic prefilter
GMAIL_SECONDARY_FILTER_MODE=off
GMAIL_SECONDARY_FILTER_PROVIDER=noop
GMAIL_SECONDARY_FILTER_MIN_CONFIDENCE=0.995
GMAIL_SECONDARY_FILTER_ENDPOINT_URL=
GMAIL_SECONDARY_FILTER_API_TOKEN=
GMAIL_SECONDARY_FILTER_TIMEOUT_SECONDS=8
GMAIL_SECONDARY_FILTER_MAX_INPUT_CHARS=1200
# If a single Gmail sync diff contains fewer than this many emails, bypass BERT entirely.
GMAIL_SECONDARY_FILTER_MIN_BATCH_SIZE=11

# Canonical LLM provider registry.
# Set INGESTION_LLM_PROVIDER_ID / AGENT_LLM_PROVIDER_ID to one of the named providers below.
# Supported vendors:
# - openai
# - gemini
# - dashscope_openai
#
# Example named providers:
# openai_main:
LLM_PROVIDER_OPENAI_MAIN_VENDOR=openai
LLM_PROVIDER_OPENAI_MAIN_PROTOCOL=responses
LLM_PROVIDER_OPENAI_MAIN_MODEL=
LLM_PROVIDER_OPENAI_MAIN_BASE_URL=https://api.openai.com/v1
LLM_PROVIDER_OPENAI_MAIN_API_KEY=
LLM_PROVIDER_OPENAI_MAIN_RESPONSES_BASE_URL=
LLM_PROVIDER_OPENAI_MAIN_CHAT_BASE_URL=
LLM_PROVIDER_OPENAI_MAIN_TIMEOUT_SECONDS=
LLM_PROVIDER_OPENAI_MAIN_MAX_RETRIES=
LLM_PROVIDER_OPENAI_MAIN_MAX_INPUT_CHARS=
LLM_PROVIDER_OPENAI_MAIN_EXTRA_BODY_JSON=
LLM_PROVIDER_OPENAI_MAIN_FALLBACK_PROVIDER_IDS=openai_chat

LLM_PROVIDER_OPENAI_CHAT_VENDOR=openai
LLM_PROVIDER_OPENAI_CHAT_PROTOCOL=chat_completions
LLM_PROVIDER_OPENAI_CHAT_MODEL=
LLM_PROVIDER_OPENAI_CHAT_BASE_URL=https://api.openai.com/v1
LLM_PROVIDER_OPENAI_CHAT_API_KEY=
LLM_PROVIDER_OPENAI_CHAT_TIMEOUT_SECONDS=
LLM_PROVIDER_OPENAI_CHAT_MAX_RETRIES=
LLM_PROVIDER_OPENAI_CHAT_MAX_INPUT_CHARS=
LLM_PROVIDER_OPENAI_CHAT_EXTRA_BODY_JSON=

# gemini_main:
LLM_PROVIDER_GEMINI_MAIN_VENDOR=gemini
LLM_PROVIDER_GEMINI_MAIN_PROTOCOL=gemini_generate_content
LLM_PROVIDER_GEMINI_MAIN_MODEL=
LLM_PROVIDER_GEMINI_MAIN_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
LLM_PROVIDER_GEMINI_MAIN_API_KEY=
LLM_PROVIDER_GEMINI_MAIN_TIMEOUT_SECONDS=
LLM_PROVIDER_GEMINI_MAIN_MAX_RETRIES=
LLM_PROVIDER_GEMINI_MAIN_MAX_INPUT_CHARS=
LLM_PROVIDER_GEMINI_MAIN_EXTRA_BODY_JSON=
LLM_PROVIDER_GEMINI_MAIN_FALLBACK_PROVIDER_IDS=gemini_compat

LLM_PROVIDER_GEMINI_COMPAT_VENDOR=gemini
LLM_PROVIDER_GEMINI_COMPAT_PROTOCOL=chat_completions
LLM_PROVIDER_GEMINI_COMPAT_MODEL=
LLM_PROVIDER_GEMINI_COMPAT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_PROVIDER_GEMINI_COMPAT_API_KEY=
LLM_PROVIDER_GEMINI_COMPAT_TIMEOUT_SECONDS=
LLM_PROVIDER_GEMINI_COMPAT_MAX_RETRIES=
LLM_PROVIDER_GEMINI_COMPAT_MAX_INPUT_CHARS=
LLM_PROVIDER_GEMINI_COMPAT_EXTRA_BODY_JSON=

# qwen_us_main (DashScope US / 百炼美国):
# Mainline ingestion + agent traffic should stay on qwen.
# Leave provider-level fallback ids empty unless you intentionally add
# another same-vendor qwen provider and want explicit provider fallback.
LLM_PROVIDER_QWEN_US_MAIN_VENDOR=dashscope_openai
LLM_PROVIDER_QWEN_US_MAIN_PROTOCOL=responses
LLM_PROVIDER_QWEN_US_MAIN_MODEL=qwen3.5-flash
LLM_PROVIDER_QWEN_US_MAIN_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
LLM_PROVIDER_QWEN_US_MAIN_RESPONSES_BASE_URL=https://dashscope-us.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1
LLM_PROVIDER_QWEN_US_MAIN_CHAT_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
LLM_PROVIDER_QWEN_US_MAIN_API_KEY=
LLM_PROVIDER_QWEN_US_MAIN_TIMEOUT_SECONDS=
LLM_PROVIDER_QWEN_US_MAIN_MAX_RETRIES=
LLM_PROVIDER_QWEN_US_MAIN_MAX_INPUT_CHARS=
LLM_PROVIDER_QWEN_US_MAIN_EXTRA_BODY_JSON='{"enable_thinking":false}'
LLM_PROVIDER_QWEN_US_MAIN_FALLBACK_PROVIDER_IDS=

LLM_PROVIDER_QWEN_US_CHAT_VENDOR=dashscope_openai
LLM_PROVIDER_QWEN_US_CHAT_PROTOCOL=chat_completions
LLM_PROVIDER_QWEN_US_CHAT_MODEL=qwen3.5-flash
LLM_PROVIDER_QWEN_US_CHAT_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
LLM_PROVIDER_QWEN_US_CHAT_API_KEY=
LLM_PROVIDER_QWEN_US_CHAT_TIMEOUT_SECONDS=
LLM_PROVIDER_QWEN_US_CHAT_MAX_RETRIES=
LLM_PROVIDER_QWEN_US_CHAT_MAX_INPUT_CHARS=
LLM_PROVIDER_QWEN_US_CHAT_EXTRA_BODY_JSON='{"enable_thinking":false}'

# DashScope US qwen-flash <=256K pricing defaults for replay closeout.
# Override these if you switch models or need a different pricing tier.
LLM_PRICE_QWEN_US_MAIN_INPUT_PER_1M_USD=0.05
LLM_PRICE_QWEN_US_MAIN_CACHED_INPUT_PER_1M_USD=0.01
LLM_PRICE_QWEN_US_MAIN_OUTPUT_PER_1M_USD=0.40
LLM_PRICE_QWEN_US_CHAT_INPUT_PER_1M_USD=0.05
LLM_PRICE_QWEN_US_CHAT_CACHED_INPUT_PER_1M_USD=0.01
LLM_PRICE_QWEN_US_CHAT_OUTPUT_PER_1M_USD=0.40

INGESTION_LLM_PROVIDER_ID=qwen_us_main
AGENT_LLM_PROVIDER_ID=qwen_us_main

# Reserve gemini for explicit future lanes (for example embedding or
# explicitly selected experiments). It should not be selected implicitly by
# the mainline ingestion/agent provider ids.

INGESTION_LLM_SESSION_CACHE_ENABLED=true

# Optional: separate agent/copilot model settings.
# Agent generation remains deterministic by default. Set to `llm_assisted`
# only when you want proposal summary/reason copy to route through the provider selected by AGENT_LLM_PROVIDER_ID.
AGENT_GENERATION_MODE=deterministic

# Required for monolith queue/runtime
REDIS_URL=redis://localhost:6379/0
LLM_QUEUE_STREAM_KEY=llm:parse:stream
LLM_QUEUE_GROUP=llm-parse-workers
LLM_QUEUE_CONSUMER_POLL_MS=500
LLM_WORKER_CONCURRENCY=12
LLM_RETRY_BASE_SECONDS=30
LLM_RETRY_MAX_SECONDS=600
LLM_RETRY_JITTER_SECONDS=5
LLM_MAX_RETRY_ATTEMPTS=6
LLM_CLAIM_TIMEOUT_SECONDS=300
LLM_REQUEST_WINDOW_SECONDS=60
LLM_MAX_REQUESTS_PER_WINDOW=480
# Recommended starting point on smaller hosts (for example 2c2g ECS):
# keep worker/sample concurrency around 12, then tune upward only if the
# 60-second request window is not being saturated and error rate stays stable.

# Optional: runtime worker loop intervals (seconds)
INGESTION_TICK_SECONDS=2
REVIEW_APPLY_TICK_SECONDS=2
NOTIFICATION_TICK_SECONDS=5
