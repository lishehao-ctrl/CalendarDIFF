# Core runtime only (minimal local setup)
# Optional Gmail OAuth / SMTP / test config are documented in README.
APP_API_KEY=dev-api-key-change-me
APP_SECRET_KEY=7J2Btjj4GW8jIP5MErM81QOZeK4c7xYknVxKsgKMnmk=
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/deadline_diff
ENABLE_NOTIFICATIONS=false

# Optional: Gmail OAuth (only needed if you use "Connect Gmail" in /ui/inputs)
# Use a Google OAuth client secrets file (Web application) and keep it outside this repository.
APP_BASE_URL=http://localhost:8000
GMAIL_OAUTH_CLIENT_SECRETS_FILE=/absolute/path/outside-repo/client_secret.jsonl
# The file can be .json or .jsonl, but must contain Google client secrets JSON with a "web" object.
# The first redirect URI in that file must be exactly: http://localhost:8000/v2/oauth-callbacks/gmail
# Recommended: chmod 600 /absolute/path/outside-repo/client_secret.jsonl
# Keep readonly unless you intentionally expand scopes
GMAIL_OAUTH_SCOPE=https://www.googleapis.com/auth/gmail.readonly

# Optional: Ingestion LLM (chat completions only, OpenAI-compatible)
INGESTION_LLM_MODEL=gpt-5.3-codex
INGESTION_LLM_BASE_URL=
INGESTION_LLM_API_KEY=
